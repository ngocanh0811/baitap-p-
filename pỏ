            document.getElementById('txt-contact-name').innerText = name;
            document.getElementById('txt-contact-email').innerText = email;
            document.getElementById('txt-contact-email').href = "mailto:" + email;
            document.getElementById('txt-contact-phone').innerText = phone;
            document.getElementById('txt-contact-fb').innerText = fb;
            document.getElementById('txt-contact-fb').href = fb;
            document.getElementById('txt-contact-git').innerText = git;
            document.getElementById('txt-contact-git').href = git;

            localStorage.setItem('pf_c_name', name);
            localStorage.setItem('pf_c_email', email);
            localStorage.setItem('pf_c_phone', phone);
            localStorage.setItem('pf_c_fb', fb);
            localStorage.setItem('pf_c_git', git);
            openEditForm('contact');
        }

        /* Xử lý upload ảnh minh chứng (chuyển đổi Base64 lưu cục bộ) */
        function uploadEvidence(event, imgElementId) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const base64Url = e.target.result;
                    const img = document.getElementById(imgElementId);
                    img.src = base64Url;
                    img.style.display = 'block';
                    localStorage.setItem(`pf_img_${imgElementId}`, base64Url);
                }
                reader.readAsDataURL(file);
            }
        }

        /* Khôi phục toàn bộ dữ liệu đã chỉnh sửa từ LocalStorage khi tải trang */
        function loadStoredData() {
            if(localStorage.getItem('pf_student_name')) document.getElementById('txt-student-name').innerText = localStorage.getItem('pf_student_name');
            if(localStorage.getItem('pf_site_title')) {
                document.getElementById('txt-site-title').innerText = localStorage.getItem('pf_site_title');
                document.getElementById('site-title-nav').innerText = localStorage.getItem('pf_site_title');
            }
            if(localStorage.getItem('pf_hero_desc')) document.getElementById('txt-hero-desc').innerText = localStorage.getItem('pf_hero_desc');
            
            if(localStorage.getItem('pf_major')) document.getElementById('txt-major').innerText = localStorage.getItem('pf_major');
            if(localStorage.getItem('pf_hobbies')) document.getElementById('txt-hobbies').innerText = localStorage.getItem('pf_hobbies');
            if(localStorage.getItem('pf_career')) document.getElementById('txt-career').innerText = localStorage.getItem('pf_career');
            if(localStorage.getItem('pf_ai-target')) document.getElementById('txt-ai-target').innerText = localStorage.getItem('pf_ai-target');

            // Khôi phục dữ liệu cho 6 bài tập
            for(let i=1; i<=6; i++) {
                if(localStorage.getItem(`pf_title_ex${i}`)) document.getElementById(`title-ex${i}`).innerText = localStorage.getItem(`pf_title_ex${i}`);
                if(localStorage.getItem(`pf_desc_ex${i}`)) document.getElementById(`desc-ex${i}`).innerText = localStorage.getItem(`pf_desc_ex${i}`);
                if(localStorage.getItem(`pf_struct_ex${i}`)) document.getElementById(`struct-ex${i}`).innerText = localStorage.getItem(`pf_struct_ex${i}`);
                if(localStorage.getItem(`pf_rule_ex${i}`)) document.getElementById(`rule-ex${i}`).innerText = localStorage.getItem(`pf_rule_ex${i}`);
                
                // Khôi phục ảnh minh họa bài tập
                const storedImg = localStorage.getItem(`pf_img_img-ex${i}`);
                if(storedImg) {
                    const img = document.getElementById(`img-ex${i}`);
                    img.src = storedImg;
                    img.style.display = 'block';
                }
            }

            if(localStorage.getItem('pf_reflection')) document.getElementById('txt-reflection').innerText = localStorage.getItem('pf_reflection');

            if(localStorage.getItem('pf_c_name')) document.getElementById('txt-contact-name').innerText = localStorage.getItem('pf_c_name');
            if(localStorage.getItem('pf_c_email')) {
                document.getElementById('txt-contact-email').innerText = localStorage.getItem('pf_c_email');
                document.getElementById('txt-contact-email').href = "mailto:" + localStorage.getItem('pf_c_email');
            }
            if(localStorage.getItem('pf_c_phone')) document.getElementById('txt-contact-phone').innerText = localStorage.getItem('pf_c_phone');
            if(localStorage.getItem('pf_c_fb')) {
                document.getElementById('txt-contact-fb').innerText = localStorage.getItem('pf_c_fb');
                document.getElementById('txt-contact-fb').href = localStorage.getItem('pf_c_fb');
            }
            if(localStorage.getItem('pf_c_git')) {
                document.getElementById('txt-contact-git').innerText = localStorage.getItem('pf_c_git');
                document.getElementById('txt-contact-git').href = localStorage.getItem('pf_c_git');
            }
        }

        // Bắt đầu ứng dụng
        window.onload = function() {
            loadStoredData();
            checkLoginStatus();
        };

        // Chuyển hướng ảo hỗ trợ đường dẫn /admin thông qua hash URL
        window.addEventListener('hashchange', function() {
            if(window.location.hash === '#admin') {
                document.getElementById('admin').scrollIntoView();
            }
        });
    </script>
</body>
</html>
